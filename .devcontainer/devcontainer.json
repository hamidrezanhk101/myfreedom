{
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "forwardPorts": [2053, 8080],
  "portsAttributes": {
    "2053": {
      "label": "3x-ui Panel",
      "protocol": "https",
      "visibility": "public"
    },
    "8080": {
      "label": "Proxy Connection",
      "protocol": "https",
      "visibility": "public"
    }
  },
  "postStartCommand": "bash .devcontainer/start.sh"
}

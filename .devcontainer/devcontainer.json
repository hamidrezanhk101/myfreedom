{
  "name": "g2ray",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "postAttachCommand": {
    "expose": "gh codespace ports visibility 443:public -c $CODESPACE_NAME"
  },
  "portsAttributes": {
    "443": {
      "label": "g2ray",
      "protocol": "tcp",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [443],
  "hostRequirements": {
    "cpus": 2
  }
}
